# ABI-2029 Environment Variables Template
# ACHTUNG: Dies ist nur ein Template! Die echte .env wird vom setup.sh generiert.
# Nie .env in Git committen!

NODE_ENV=development
PORT=3000

# Root Admin (Hardcoded Credentials - äußerst sicher)
ROOT_ADMIN_EMAIL=admin@example.com
ROOT_ADMIN_PASSWORD_HASH=$2a$10$...bcrypt.hash...

# Session & Encryption Keys (32 Bytes Hex für AES-256)
SESSION_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
DB_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Database Path
DB_PATH=./db/database.json
