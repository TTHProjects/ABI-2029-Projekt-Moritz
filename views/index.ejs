<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ABI-2029 | Maria-Wächtler Gymnasium</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Custom Styles für Liquid Glass Ästhetik -->
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #0a0f1e;
      --secondary: #2d0a4e;
      --accent: #7c3aed;
      --glass-light: rgba(255, 255, 255, 0.1);
      --glass-border: rgba(255, 255, 255, 0.2);
    }

    body {
      background: linear-gradient(135deg, #0a0f1e 0%, #1a0f2e 50%, #0a0f1e 100%);
      background-attachment: fixed;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif;
      color: #e0e0ff;
      min-height: 100vh;
    }

    /* Liquid Glass Komponenten */
    .glass {
      background: rgba(45, 10, 78, 0.15);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 16px;
      box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
    }

    .glass-sm {
      background: rgba(45, 10, 78, 0.1);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 12px;
    }

    .glass-hover:hover {
      background: rgba(45, 10, 78, 0.25);
      border-color: rgba(255, 255, 255, 0.3);
      transition: all 0.3s ease;
    }

    .gradient-accent {
      background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
    }

    .text-gradient {
      background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .btn-primary {
      background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
      color: white;
      padding: 10px 24px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(124, 58, 237, 0.6);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.1);
      color: #e0e0ff;
      padding: 10px 24px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.15);
      border-color: rgba(255, 255, 255, 0.3);
    }

    input, textarea, select {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: #e0e0ff;
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    input:focus, textarea:focus, select:focus {
      outline: none;
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(124, 58, 237, 0.5);
      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
    }

    input::placeholder {
      color: rgba(224, 224, 255, 0.5);
    }

    .card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 20px;
      transition: all 0.3s ease;
    }

    .card:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(124, 58, 237, 0.3);
    }

    .navbar {
      background: rgba(10, 15, 30, 0.7);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .status-badge {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .status-paid {
      background: rgba(34, 197, 94, 0.2);
      color: #86efac;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .status-pending {
      background: rgba(249, 115, 22, 0.2);
      color: #fdba74;
      border: 1px solid rgba(249, 115, 22, 0.3);
    }

    .status-approved {
      background: rgba(59, 130, 246, 0.2);
      color: #93c5fd;
      border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .status-pending-approval {
      background: rgba(168, 85, 247, 0.2);
      color: #d8b4fe;
      border: 1px solid rgba(168, 85, 247, 0.3);
    }

    .fade-in {
      animation: fadeIn 0.5s ease-in;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .alert {
      padding: 16px;
      border-radius: 8px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .alert-error {
      background: rgba(239, 68, 68, 0.2);
      color: #fca5a5;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .alert-success {
      background: rgba(34, 197, 94, 0.2);
      color: #86efac;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .alert-info {
      background: rgba(59, 130, 246, 0.2);
      color: #93c5fd;
      border: 1px solid rgba(59, 130, 246, 0.3);
    }
  </style>
</head>
<body>
  <!-- NAVBAR -->
  <% if (page !== 'login') { %>
    <nav class="navbar sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 gradient-accent rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">29</span>
          </div>
          <h1 class="text-xl font-bold text-gradient">ABI-2029</h1>
        </div>

        <div class="flex items-center gap-6">
          <% if (user) { %>
            <span class="text-sm text-gray-400">
              <% if (user.isRootAdmin) { %>
                👑 Root Admin
              <% } else { %>
                <%= user.name || user.email %>
              <% } %>
            </span>
            <a href="/logout" class="btn-secondary text-xs px-3 py-2">
              Abmelden
            </a>
          <% } %>
        </div>
      </div>
    </nav>
  <% } %>

  <main class="<%= page !== 'login' ? 'py-8' : '' %>">
    <!-- LOGIN PAGE -->
    <% if (page === 'login') { %>
      <div class="min-h-screen flex items-center justify-center px-4">
        <div class="w-full max-w-md">
          <!-- Logo & Title -->
          <div class="text-center mb-8 fade-in">
            <div class="w-16 h-16 gradient-accent rounded-2xl flex items-center justify-center mx-auto mb-4">
              <span class="text-white font-bold text-4xl">29</span>
            </div>
            <h1 class="text-4xl font-bold text-gradient mb-2">ABI-2029</h1>
            <p class="text-gray-400">Maria-Wächtler Gymnasium</p>
          </div>

          <!-- Login Form -->
          <div class="glass p-8 fade-in">
            <h2 class="text-2xl font-bold mb-6">Login</h2>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert alert-error mb-4">
                <span>⚠️</span>
                <span><%= error %></span>
              </div>
            <% } %>

            <form method="POST" action="/login" class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Email</label>
                <input
                  type="email"
                  name="email"
                  placeholder="deine@email.de"
                  required
                  class="w-full"
                />
              </div>

              <div>
                <label class="block text-sm font-medium mb-2">Passwort</label>
                <input
                  type="password"
                  name="password"
                  placeholder="••••••••"
                  required
                  class="w-full"
                />
              </div>

              <button type="submit" class="w-full btn-primary mt-6">
                Anmelden
              </button>
            </form>

            <div class="mt-6 pt-6 border-t border-gray-700 text-center text-sm text-gray-400">
              <p>Noch kein Konto? Kontaktiere einen Administrator.</p>
            </div>
          </div>

          <!-- Footer -->
          <div class="mt-8 text-center text-xs text-gray-500">
            <p>🔐 Datensicherheit durch AES-256 Verschlüsselung</p>
          </div>
        </div>
      </div>

    <!-- DASHBOARD PAGE -->
    <% } else if (page === 'dashboard') { %>
      <div class="max-w-7xl mx-auto px-4">
        <div class="mb-8 fade-in">
          <h1 class="text-4xl font-bold text-gradient mb-2">
            Willkommen, <%= user.name || 'Schüler' %>!
          </h1>
          <p class="text-gray-400">Dein Abitur-Verwaltungs-Dashboard</p>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <!-- Abikassa Status -->
          <div class="card fade-in hover:scale-105 transform transition-all">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-sm font-semibold text-gray-400">Abikassa</h3>
              <span class="text-2xl">💰</span>
            </div>
            <div class="mb-4">
              <p class="text-3xl font-bold text-gradient">
                <%= user.abikassaStatus ? user.abikassaStatus.bezahlt.toFixed(2) : '0.00' %> €
              </p>
              <p class="text-xs text-gray-500 mt-1">bezahlt</p>
            </div>
            <% if (user.abikassaStatus && user.abikassaStatus.offen > 0) { %>
              <div class="pt-4 border-t border-gray-700">
                <p class="text-xs text-orange-400">⚠️ <%= user.abikassaStatus.offen.toFixed(2) %> € ausstehend</p>
              </div>
            <% } %>
          </div>

          <!-- Account Status -->
          <div class="card fade-in hover:scale-105 transform transition-all">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-sm font-semibold text-gray-400">Status</h3>
              <span class="text-2xl">✅</span>
            </div>
            <% if (user.approved !== false) { %>
              <span class="status-badge status-approved">Bestätigt</span>
            <% } else { %>
              <span class="status-badge status-pending-approval">Ausstehend</span>
            <% } %>
            <p class="text-xs text-gray-500 mt-4">
              Seit: <%= new Date(user.createdAt).toLocaleDateString('de-DE') %>
            </p>
          </div>

          <!-- Role -->
          <div class="card fade-in hover:scale-105 transform transition-all">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-sm font-semibold text-gray-400">Rolle</h3>
              <span class="text-2xl"><%= user.isRootAdmin ? '👑' : '👤' %></span>
            </div>
            <p class="text-lg font-semibold">
              <% if (user.isRootAdmin) { %>
                Root Admin
              <% } else if (user.role === 'admin') { %>
                Administrator
              <% } else if (user.role === 'kasse') { %>
                Kassenwart
              <% } else if (user.role === 'planung') { %>
                Planer
              <% } else { %>
                Schüler
              <% } %>
            </p>
            <% if (user.isRootAdmin) { %>
              <a href="/admin" class="text-xs text-purple-400 hover:text-purple-300 mt-2 inline-block">
                Admin-Panel →
              </a>
            <% } %>
          </div>
        </div>

        <!-- Events & News -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Upcoming Events -->
          <div class="glass p-6 fade-in">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
              📅 Kommende Events
            </h2>
            <% if (user.events && user.events.length > 0) { %>
              <div class="space-y-3">
                <% user.events.forEach(event => { %>
                  <div class="glass-sm p-3">
                    <p class="font-semibold"><%= event.title %></p>
                    <p class="text-xs text-gray-400 mt-1"><%= event.date %></p>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <p class="text-gray-400 text-sm">Keine Events geplant</p>
            <% } %>
          </div>

          <!-- News -->
          <div class="glass p-6 fade-in">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
              📢 Neuigkeiten
            </h2>
            <% if (user.news && user.news.length > 0) { %>
              <div class="space-y-3">
                <% user.news.forEach(news => { %>
                  <div class="glass-sm p-3">
                    <p class="font-semibold text-sm"><%= news.title %></p>
                    <p class="text-xs text-gray-500 mt-1"><%= news.date %></p>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <p class="text-gray-400 text-sm">Keine News</p>
            <% } %>
          </div>
        </div>
      </div>

    <!-- ADMIN PAGE -->
    <% } else if (page === 'admin') { %>
      <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-4xl font-bold text-gradient mb-8 fade-in">
          👑 Admin-Panel
        </h1>

        <!-- Admin Stats -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <div class="card fade-in">
            <p class="text-gray-400 text-sm mb-2">Gesamt User</p>
            <p class="text-3xl font-bold text-gradient"><%= stats.userCount %></p>
          </div>
          <div class="card fade-in">
            <p class="text-gray-400 text-sm mb-2">Events</p>
            <p class="text-3xl font-bold text-gradient"><%= stats.eventCount %></p>
          </div>
          <div class="card fade-in">
            <p class="text-gray-400 text-sm mb-2">Gesamteinkünfte</p>
            <p class="text-3xl font-bold text-gradient"><%= stats.totalPayments %> €</p>
          </div>
          <div class="card fade-in">
            <p class="text-gray-400 text-sm mb-2">System</p>
            <p class="text-sm text-green-400 font-semibold">🟢 Online</p>
          </div>
        </div>

        <!-- Admin Sections -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="glass p-6 fade-in">
            <h2 class="text-xl font-bold mb-4">👥 User-Verwaltung</h2>
            <p class="text-gray-400 mb-4">Verwalte Benutzer, Rollen und Zugriffsrechte</p>
            <button class="btn-primary">User-Verwaltung öffnen</button>
          </div>

          <div class="glass p-6 fade-in">
            <h2 class="text-xl font-bold mb-4">💰 Kassenverwaltung</h2>
            <p class="text-gray-400 mb-4">Zahlungen quittieren und Konten verwalten</p>
            <button class="btn-primary">Kasse öffnen</button>
          </div>

          <div class="glass p-6 fade-in">
            <h2 class="text-xl font-bold mb-4">📅 Event-Planung</h2>
            <p class="text-gray-400 mb-4">Events und Termine erstellen und verwalten</p>
            <button class="btn-primary">Events verwalten</button>
          </div>

          <div class="glass p-6 fade-in">
            <h2 class="text-xl font-bold mb-4">⚙️ System</h2>
            <p class="text-gray-400 mb-4">Systemeinstellungen und Sicherheit</p>
            <button class="btn-primary">Einstellungen</button>
          </div>
        </div>
      </div>

    <!-- 404 PAGE -->
    <% } else if (page === '404') { %>
      <div class="min-h-screen flex items-center justify-center">
        <div class="text-center">
          <h1 class="text-6xl font-bold text-gradient mb-4">404</h1>
          <p class="text-xl text-gray-400 mb-6">Seite nicht gefunden</p>
          <a href="/" class="btn-primary">Zurück zur Startseite</a>
        </div>
      </div>

    <% } %>
  </main>

  <!-- Footer (nur wenn nicht Login) -->
  <% if (page !== 'login') { %>
    <footer class="mt-12 py-6 border-t border-gray-800">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500">
        <p>🔐 SHADOW-JSON: Hochsichere Abitur-Verwaltungsplattform</p>
        <p class="mt-2">© 2026 Maria-Wächtler Gymnasium | Abiturjahrgang 2029</p>
      </div>
    </footer>
  <% } %>
</body>
</html>
